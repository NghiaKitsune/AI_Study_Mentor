<?xml version="1.0" encoding="utf-8"?>
<!--
    AI Study Mentor - Material 3 Theme
    Drop into: app/src/main/res/values/themes.xml
    Requires: com.google.android.material:material:1.11.0+
    minSdk 24, targetSdk 33 (Android 13)
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme: Material 3 Light, no action bar (we draw our own TopBar) -->
    <style name="Theme.StudyMentor" parent="Theme.Material3.Light.NoActionBar">

        <!-- Color roles -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>

        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_outline</item>

        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>

        <!-- Status bar: matches background, dark icons -->
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Nav bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Material shapes override (rounded corners) -->
        <item name="shapeAppearanceSmallComponent">@style/Shape.StudyMentor.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.StudyMentor.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.StudyMentor.Large</item>
    </style>

    <!-- ============ Shape overrides ============ -->
    <style name="Shape.StudyMentor.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/radius_sm</item>
    </style>
    <style name="Shape.StudyMentor.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/radius_md</item>
    </style>
    <style name="Shape.StudyMentor.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

    <style name="Shape.StudyMentor.Round" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ============ Bottom navigation active indicator ============ -->
    <!-- Height 68dp: centered on icon (y≈24dp), extends to y≈58dp — covers icon + label -->
    <style name="BottomNav.ActiveIndicator"
           parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">@dimen/bottomnav_indicator_size</item>
        <item name="android:height">@dimen/bottomnav_indicator_size</item>
        <item name="android:color">@color/brand_primary_tint</item>
    </style>

    <!-- ============ Reusable text styles ============ -->
    <style name="Text.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="Text.H1" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.H2" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.H3" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Text.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ============ Button styles ============ -->
    <style name="Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="elevation">@dimen/elev_1</item>
    </style>

    <style name="Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Card -->
    <style name="Card.Default" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Launcher / splash theme (Android 12+ splash screen API) -->
    <style name="Theme.StudyMentor.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_mascot_milo</item>
        <item name="postSplashScreenTheme">@style/Theme.StudyMentor</item>
    </style>

    <!-- Fullscreen black theme for CameraActivity (UC2.5) -->
    <style name="Theme.StudyMentor.FullscreenBlack" parent="Theme.StudyMentor">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Chip filter style (used in Personalize subject picker) -->
    <style name="Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
