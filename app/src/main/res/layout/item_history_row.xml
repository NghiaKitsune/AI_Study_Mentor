<?xml version="1.0" encoding="utf-8"?>
<!-- Recent history row — used by Home + History -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/space_3">

    <ImageView
        android:id="@+id/img_subject_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_avatar_circle"
        android:padding="9dp"
        android:src="@drawable/ic_sparkles"
        app:tint="@color/brand_primary_darker"
        tools:ignore="ContentDescription" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_3"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_question"
            style="@style/Text.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Solve 2x + 5 = 17" />

        <TextView
            android:id="@+id/text_meta"
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="Math · 2h ago" />
    </LinearLayout>

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/text_tertiary"
        tools:ignore="ContentDescription" />
</LinearLayout>
