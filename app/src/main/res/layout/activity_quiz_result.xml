<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    tools:context=".ui.QuizResultActivity">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/appbar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_close"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_close" />

        <TextView
            style="@style/Text.H3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Quiz complete" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_share"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_share" />
    </LinearLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_5"
            android:paddingTop="@dimen/space_5"
            android:paddingBottom="@dimen/space_6">

            <!-- Hero section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="@dimen/space_6">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_mascot_milo"
                    android:contentDescription="@string/cd_mascot" />

                <!-- Score: large number + "/total" denominator -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/space_4">

                    <TextView
                        android:id="@+id/text_score_num"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_score_hero"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:letterSpacing="-0.02"
                        tools:text="4" />

                    <TextView
                        android:id="@+id/text_score_denom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_ring_value"
                        android:textStyle="bold"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginStart="@dimen/space_2"
                        tools:text="/ 5" />
                </LinearLayout>

                <!-- Result label -->
                <TextView
                    android:id="@+id/text_result_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:textSize="@dimen/text_h3"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    tools:text="Nice work!" />

                <!-- XP earned pill -->
                <TextView
                    android:id="@+id/text_xp_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:background="@drawable/bg_timer_normal"
                    android:paddingHorizontal="@dimen/space_4"
                    android:paddingVertical="6dp"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary_deep"
                    android:letterSpacing="0.04"
                    tools:text="+40 XP" />
            </LinearLayout>

            <!-- Stats row: Correct / Incorrect / Accuracy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_5">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4">
                        <TextView android:id="@+id/text_stat_correct"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/color_ok" tools:text="4" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="@dimen/text_micro" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:text="Correct" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/space_1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4">
                        <TextView android:id="@+id/text_stat_incorrect"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/error" tools:text="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="@dimen/text_micro" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:text="Incorrect" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4">
                        <TextView android:id="@+id/text_stat_accuracy"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" tools:text="80%" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="@dimen/text_micro" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:text="Accuracy" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Subject breakdown card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/space_4"
                        android:layout_marginTop="@dimen/space_4"
                        android:layout_marginBottom="@dimen/space_2"
                        android:textColor="@color/text_tertiary"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:text="By subject" />

                    <LinearLayout
                        android:id="@+id/container_breakdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/space_2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:colorBackground"
        android:elevation="4dp"
        android:padding="@dimen/space_4"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_try_again"
            style="@style/Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_md"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/space_2"
            android:text="Try again" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_home"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_md"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_2"
            android:text="Back to home" />
    </LinearLayout>

</LinearLayout>
