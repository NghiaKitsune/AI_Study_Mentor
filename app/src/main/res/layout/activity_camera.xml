<?xml version="1.0" encoding="utf-8"?>
<!--
    CameraActivity — UC2.5
    Fullscreen black layout. CameraX PreviewView fills the screen.
    Top bar: close · title pill · flash toggle
    Center: viewfinder frame with 4 amber corner brackets + hint chip
    Bottom: mode pills · gallery · shutter · flip · with a dim gradient overlay
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fitsSystemWindows="true"
    tools:context=".ui.CameraActivity">

    <!-- CameraX preview (fills the whole screen) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter"
        app:implementationMode="performance" />

    <!-- Permission-denied empty state (shown when CAMERA isn't granted) -->
    <LinearLayout
        android:id="@+id/perm_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1A1610"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_camera"
            android:contentDescription="@string/action_camera"
            app:tint="#F5B544" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/camera_perm_title"
            android:textColor="#FFF6E0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/camera_perm_body"
            android:textColor="#B5A57E"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_grant_perm"
            style="@style/Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:text="@string/camera_perm_grant" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.TextButton"
            android:id="@+id/btn_open_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/camera_perm_settings"
            android:textColor="#F5B544" />
    </LinearLayout>

    <!-- ===== Viewfinder frame guide (4 corner brackets) ===== -->
    <FrameLayout
        android:id="@+id/viewfinder_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="140dp"
        android:layout_marginBottom="220dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|start"
            android:src="@drawable/ic_frame_corner_tl"
            android:contentDescription="@null" />
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:src="@drawable/ic_frame_corner_tr"
            android:contentDescription="@null" />
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|start"
            android:src="@drawable/ic_frame_corner_bl"
            android:contentDescription="@null" />
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_frame_corner_br"
            android:contentDescription="@null" />

        <!-- Center hint chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_camera_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_target"
                android:contentDescription="@null"
                app:tint="#FFF6E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_hint"
                android:textColor="#FFF6E0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== Top bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.IconButton"
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="#80000000"
            app:icon="@drawable/ic_close"
            app:iconTint="#FFFFFF"
            app:iconSize="22dp"
            app:cornerRadius="20dp"
            android:contentDescription="@string/action_close" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_camera_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@color/brand_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_title"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.IconButton"
            android:id="@+id/btn_flash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="#80000000"
            app:icon="@drawable/ic_flash_off"
            app:iconTint="#FFFFFF"
            app:iconSize="20dp"
            app:cornerRadius="20dp"
            android:contentDescription="@string/action_camera" />
    </LinearLayout>

    <!-- ===== Bottom control bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#80000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <!-- Gallery picker -->
        <LinearLayout
            android:id="@+id/btn_gallery"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_camera_sidebtn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_image"
                android:contentDescription="@string/camera_gallery"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/camera_gallery"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Shutter -->
        <FrameLayout
            android:id="@+id/btn_shutter"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@drawable/bg_camera_shutter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/camera_shutter" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Flip camera -->
        <LinearLayout
            android:id="@+id/btn_flip"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_camera_sidebtn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_camera_flip"
                android:contentDescription="@string/camera_flip"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/camera_flip"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Processing overlay (shown after shutter while we "OCR" the image) -->
    <LinearLayout
        android:id="@+id/processing_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1A1610"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="@color/brand_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/scan_processing"
            android:textColor="#FFF6E0"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
