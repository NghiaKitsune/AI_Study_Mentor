<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <ImageView
        android:id="@+id/img_subject"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:padding="9dp"
        android:background="@drawable/bg_icon_sq"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_sparkles"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">

            <TextView
                android:id="@+id/text_subject_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Math" />

            <TextView
                android:id="@+id/text_subject_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_tertiary"
                tools:text="89 Qs · 36%" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/bar_subject"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progress="36"
            android:progressBackgroundTint="@color/surface_3" />
    </LinearLayout>
</LinearLayout>
