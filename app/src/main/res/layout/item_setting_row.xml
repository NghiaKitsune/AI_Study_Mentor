<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable row: leading icon · label/sublabel · trailing chevron -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_4"
    android:paddingVertical="@dimen/space_3">

    <ImageView
        android:id="@+id/img_row_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_sparkles"
        app:tint="@color/text_secondary"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/text_row_label"
        style="@style/Text.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_3"
        tools:text="Theme" />

    <TextView
        android:id="@+id/text_row_value"
        style="@style/Text.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/space_2"
        tools:text="System" />

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/text_tertiary"
        tools:ignore="ContentDescription" />
</LinearLayout>
