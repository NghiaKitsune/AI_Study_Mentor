<?xml version="1.0" encoding="utf-8"?>
<!--
    ProfileActivity — UC8
    TopBar | Hero avatar+level | XP bar | 3-cell stats | Badges 4x2 | Activity feed | BottomNav
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    tools:context=".ui.ProfileActivity">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/appbar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_back"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_back" />

        <TextView
            style="@style/Text.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_2"
            android:text="Profile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_settings"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_more" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@color/brand_primary_tint"
                android:paddingTop="@dimen/space_2"
                android:paddingBottom="@dimen/space_6"
                android:paddingHorizontal="@dimen/space_5">

                <!-- Avatar with gradient ring + level badge -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <!-- Gradient ring (approximated with primary bg) -->
                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_hero_gradient"
                        android:padding="4dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar_circle">

                            <ImageView
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_mascot_milo"
                                android:contentDescription="@string/cd_avatar" />
                        </FrameLayout>
                    </FrameLayout>

                    <!-- Level badge -->
                    <TextView
                        android:id="@+id/text_level_badge"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_circle"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:text="7" />
                </FrameLayout>

                <TextView
                    android:id="@+id/text_profile_name"
                    style="@style/Text.H2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    tools:text="Nghia Mentor" />

                <TextView
                    android:id="@+id/text_level_title"
                    style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:text="Level 7 · Algebra Apprentice" />

                <!-- XP progress bar -->
                <ProgressBar
                    android:id="@+id/progress_xp"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="280dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="@dimen/space_4"
                    android:max="500"
                    android:progress="340"
                    android:progressTint="@color/brand_primary"
                    android:progressBackgroundTint="@color/surface_3" />

                <LinearLayout
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView style="@style/Text.Caption" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_tertiary" android:textStyle="bold"
                        android:text="340 XP" />
                    <TextView style="@style/Text.Caption" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_tertiary" android:textStyle="bold"
                        android:text="160 XP to Level 8 →" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats row (3 cells) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="-16dp"
                android:layout_marginHorizontal="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_5">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4" android:paddingHorizontal="@dimen/space_2">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_flame" app:tint="@color/brand_accent"
                            android:layout_marginBottom="4dp" android:contentDescription="@null" />
                        <TextView android:id="@+id/text_stat_streak" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:text="7" />
                        <TextView style="@style/Text.Caption" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:gravity="center" android:text="Day streak" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="1dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4" android:paddingHorizontal="@dimen/space_2">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_zap" app:tint="@color/brand_primary"
                            android:layout_marginBottom="4dp" android:contentDescription="@null" />
                        <TextView android:id="@+id/text_stat_xp" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:text="1,840" />
                        <TextView style="@style/Text.Caption" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:gravity="center" android:text="Total XP" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Card.Default"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:paddingVertical="@dimen/space_4" android:paddingHorizontal="@dimen/space_2">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_medal" app:tint="#7C5CE6"
                            android:layout_marginBottom="4dp" android:contentDescription="@null" />
                        <TextView android:id="@+id/text_stat_badges" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:text="4 / 8" />
                        <TextView style="@style/Text.Caption" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_tertiary"
                            android:layout_marginTop="3dp" android:gravity="center" android:text="Badges" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Achievements section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_5">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/space_3">
                    <TextView style="@style/Text.Caption" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_tertiary" android:textStyle="bold"
                        android:letterSpacing="0.08" android:textAllCaps="true" android:text="Achievements" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/brand_primary_deep" android:textSize="13sp" android:textStyle="bold"
                        android:text="View all" />
                </LinearLayout>

                <!-- Badges grid 4x2 (using GridLayout) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_badges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- Recent activity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/space_4"
                android:paddingBottom="@dimen/space_10">

                <TextView style="@style/Text.Caption" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary" android:textStyle="bold" android:letterSpacing="0.08"
                    android:textAllCaps="true" android:layout_marginBottom="@dimen/space_3" android:text="Recent activity" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottomnav_height"
        app:menu="@menu/bottom_nav"
        app:itemIconTint="@color/text_primary"
        app:itemTextColor="@color/text_primary"
        app:itemActiveIndicatorStyle="@style/BottomNav.ActiveIndicator"
        app:itemIconSize="24dp"
        app:labelVisibilityMode="labeled"
        android:background="@color/surface"
        android:elevation="8dp" />
</LinearLayout>
