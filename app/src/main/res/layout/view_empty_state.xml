<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable empty state — mascot · title · body · optional CTA.
    Hidden by default; use View.VISIBLE to show.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/empty_state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/space_8"
    android:visibility="gone"
    tools:visibility="visible">

    <ImageView
        android:layout_width="@dimen/mascot_lg"
        android:layout_height="@dimen/mascot_lg"
        android:src="@drawable/ic_mascot_milo"
        android:alpha="0.7"
        android:contentDescription="@string/cd_mascot" />

    <TextView
        android:id="@+id/empty_title"
        style="@style/Text.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_5"
        android:gravity="center"
        tools:text="No questions yet" />

    <TextView
        android:id="@+id/empty_body"
        style="@style/Text.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_2"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        tools:text="Tap the composer to ask Milo something." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/empty_cta"
        style="@style/Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/button_height_md"
        android:layout_marginTop="@dimen/space_5"
        android:paddingHorizontal="@dimen/space_6"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="Ask Milo" />
</LinearLayout>
