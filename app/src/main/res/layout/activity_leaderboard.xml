<?xml version="1.0" encoding="utf-8"?>
<!--
    LeaderboardActivity — UC8
    TopBar | Tab bar (Global/Friends/Week) | Podium top3 | Rank list with YOU highlighted
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    tools:context=".ui.LeaderboardActivity">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/appbar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_back"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_back" />

        <TextView
            style="@style/Text.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_2"
            android:text="Leaderboard" />

        <!-- Timer countdown pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@color/surface_2"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/space_3">
            <ImageView android:layout_width="12dp" android:layout_height="12dp"
                android:src="@drawable/ic_history" app:tint="@color/text_tertiary"
                android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="4dp" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:textStyle="bold" android:text="4d 12h" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_2"
        android:padding="4dp"
        android:layout_marginHorizontal="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_3">

        <TextView
            android:id="@+id/tab_global"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@color/surface"
            android:text="Global" />

        <TextView
            android:id="@+id/tab_friends"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_tertiary"
            android:background="@android:color/transparent"
            android:text="Friends" />

        <TextView
            android:id="@+id/tab_week"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_tertiary"
            android:background="@android:color/transparent"
            android:text="This week" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_4"
            android:paddingBottom="@dimen/space_5">

            <!-- Podium section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_4"
                app:cardBackgroundColor="@color/brand_primary_tint"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_5">

                    <!-- Podium avatars row: 2nd | 1st | 3rd -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <!-- 2nd place (silver) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/podium2_name" android:layout_width="50dp" android:layout_height="50dp"
                                android:gravity="center" android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:background="@drawable/bg_avatar_circle"
                                android:layout_marginBottom="@dimen/space_2" tools:text="Mi" />
                            <TextView android:id="@+id/podium2_user" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginBottom="2dp" tools:text="MinhKhoi" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center" android:orientation="horizontal">
                                <ImageView android:layout_width="10dp" android:layout_height="10dp"
                                    android:src="@drawable/ic_zap" app:tint="@color/brand_primary_deep"
                                    android:contentDescription="@null" />
                                <TextView android:id="@+id/podium2_xp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold"
                                    android:textColor="@color/brand_primary_deep" android:layout_marginStart="2dp"
                                    tools:text="4,820" />
                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="72dp"
                                android:background="#C0C0C0" android:layout_marginTop="@dimen/space_2"
                                android:layout_marginHorizontal="4dp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:text="2" />
                        </LinearLayout>

                        <!-- 1st place (gold) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                                android:src="@drawable/ic_crown" app:tint="#F5B544"
                                android:layout_marginBottom="2dp" android:contentDescription="@null" />
                            <TextView android:id="@+id/podium1_name" android:layout_width="60dp" android:layout_height="60dp"
                                android:gravity="center" android:textSize="18sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:background="@drawable/bg_avatar_circle"
                                android:layout_marginBottom="@dimen/space_2" tools:text="An" />
                            <TextView android:id="@+id/podium1_user" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginBottom="2dp" tools:text="AnNguyen" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center" android:orientation="horizontal">
                                <ImageView android:layout_width="10dp" android:layout_height="10dp"
                                    android:src="@drawable/ic_zap" app:tint="@color/brand_primary_deep"
                                    android:contentDescription="@null" />
                                <TextView android:id="@+id/podium1_xp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold"
                                    android:textColor="@color/brand_primary_deep" android:layout_marginStart="2dp"
                                    tools:text="5,460" />
                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="96dp"
                                android:background="@color/brand_primary" android:layout_marginTop="@dimen/space_2"
                                android:layout_marginHorizontal="4dp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:text="1" />
                        </LinearLayout>

                        <!-- 3rd place (bronze) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/podium3_name" android:layout_width="50dp" android:layout_height="50dp"
                                android:gravity="center" android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:background="@drawable/bg_avatar_circle"
                                android:layout_marginBottom="@dimen/space_2" tools:text="Th" />
                            <TextView android:id="@+id/podium3_user" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginBottom="2dp" tools:text="ThaoP" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:gravity="center" android:orientation="horizontal">
                                <ImageView android:layout_width="10dp" android:layout_height="10dp"
                                    android:src="@drawable/ic_zap" app:tint="@color/brand_primary_deep"
                                    android:contentDescription="@null" />
                                <TextView android:id="@+id/podium3_xp" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold"
                                    android:textColor="@color/brand_primary_deep" android:layout_marginStart="2dp"
                                    tools:text="4,310" />
                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="56dp"
                                android:background="#CD7F32" android:layout_marginTop="@dimen/space_2"
                                android:layout_marginHorizontal="4dp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:text="3" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rank list (4-9) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_ranks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
