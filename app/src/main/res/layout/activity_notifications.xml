<?xml version="1.0" encoding="utf-8"?>
<!--
    NotificationsActivity — UC9
    TopBar | Filter chips (All/Reminders/Wins/Review) | Notification list
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    tools:context=".ui.NotificationsActivity">

    <!-- TopBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/appbar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_back"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_2"
            android:orientation="vertical">

            <TextView
                style="@style/Text.H2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_h1"
                android:text="Notifications" />

            <TextView
                android:id="@+id/text_unread_count"
                style="@style/Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                tools:text="3 new" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            app:icon="@drawable/ic_settings"
            app:iconTint="@color/text_primary"
            android:contentDescription="@string/action_more" />
    </LinearLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_3"
        android:paddingHorizontal="@dimen/space_4"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chips_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacing="@dimen/space_2"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip style="@style/Chip.Filter"
                android:id="@+id/chip_all" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="All" android:checked="true" />

            <com.google.android.material.chip.Chip style="@style/Chip.Filter"
                android:id="@+id/chip_reminders" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Reminders" />

            <com.google.android.material.chip.Chip style="@style/Chip.Filter"
                android:id="@+id/chip_wins" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Wins" />

            <com.google.android.material.chip.Chip style="@style/Chip.Filter"
                android:id="@+id/chip_review" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Review" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Notification list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_notifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/space_4"
        android:scrollbars="none"
        android:clipToPadding="false" />
</LinearLayout>
