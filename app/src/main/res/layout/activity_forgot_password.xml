<?xml version="1.0" encoding="utf-8"?>
<!--
    ForgotPasswordActivity — UC1
    Single layout with 2 stacked sub-views. ViewSwitcher logic in code.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true"
    tools:context=".ui.ForgotPasswordActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===== State 1: form ===== -->
        <LinearLayout
            android:id="@+id/view_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_6"
            android:paddingTop="@dimen/space_6"
            android:paddingBottom="@dimen/space_8">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/icon_button_lg"
                android:layout_height="@dimen/icon_button_lg"
                android:layout_gravity="start"
                app:icon="@drawable/ic_back"
                app:iconTint="@color/text_primary"
                android:contentDescription="@string/action_back" />

            <ImageView
                android:layout_width="@dimen/mascot_md"
                android:layout_height="@dimen/mascot_md"
                android:layout_marginTop="@dimen/space_4"
                android:src="@drawable/ic_mascot_milo"
                android:contentDescription="@string/cd_mascot" />

            <TextView
                style="@style/Text.Display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:text="@string/forgot_title" />

            <TextView
                style="@style/Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:textColor="@color/text_secondary"
                android:text="@string/forgot_subtitle" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_6"
                android:hint="Email"
                app:startIconDrawable="@drawable/ic_mail"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send"
                style="@style/Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_lg"
                android:layout_marginTop="@dimen/space_6"
                android:text="@string/forgot_send_cta" />
        </LinearLayout>

        <!-- ===== State 2: success ===== -->
        <LinearLayout
            android:id="@+id/view_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_6"
            android:paddingTop="@dimen/space_10"
            android:paddingBottom="@dimen/space_8"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="@dimen/mascot_lg"
                android:layout_height="@dimen/mascot_lg"
                android:src="@drawable/ic_mascot_milo"
                android:contentDescription="@string/cd_mascot" />

            <TextView
                style="@style/Text.Display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:gravity="center"
                android:text="@string/forgot_success_title" />

            <TextView
                android:id="@+id/text_success_body"
                style="@style/Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                tools:text="We sent a reset link to your@email.com. Check your inbox and follow the link." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back_to_login"
                style="@style/Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_lg"
                android:layout_marginTop="@dimen/space_6"
                android:text="@string/btn_back_to_login" />
        </LinearLayout>
    </FrameLayout>
</androidx.core.widget.NestedScrollView>
