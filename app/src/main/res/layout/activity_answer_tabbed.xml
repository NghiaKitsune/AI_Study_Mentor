<?xml version="1.0" encoding="utf-8"?>
<!--
    AnswerTabbedActivity — UC4 Tabbed Answer variant
    Dark header (question) | Scrollable tab bar | Content pane | Floating composer
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.AnswerTabbedActivity">

    <!-- Dark header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/text_primary"
        android:orientation="vertical"
        android:paddingBottom="@dimen/space_5">

        <!-- Back + SOLVED pill + Bookmark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/appbar_height"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/space_3">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/icon_button_md"
                android:layout_height="@dimen/icon_button_md"
                app:icon="@drawable/ic_back"
                app:iconTint="@color/bg" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_scan_confidence"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/space_3">

                    <ImageView android:layout_width="12dp" android:layout_height="12dp"
                        android:src="@drawable/ic_check" app:tint="@color/brand_primary"
                        android:contentDescription="@null" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:textColor="@color/brand_primary"
                        android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.06"
                        android:text="SOLVED" />
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bookmark"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/icon_button_md"
                android:layout_height="@dimen/icon_button_md"
                app:icon="@drawable/ic_bookmark"
                app:iconTint="@color/bg" />
        </LinearLayout>

        <!-- Question text in header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_4">

            <TextView
                style="@style/Text.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/space_2"
                android:text="QUESTION" />

            <TextView
                android:id="@+id/text_question"
                style="@style/Text.H3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/bg"
                android:lineSpacingMultiplier="1.3"
                tools:text="Why does the sky appear blue during the day but red at sunset?" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/space_3">

                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_sparkles" app:tint="@color/brand_primary"
                    android:layout_marginEnd="@dimen/space_2" android:contentDescription="@null" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#99F8EFD9" android:textSize="12sp" android:textStyle="bold"
                    android:text="Physics · Optics" />

                <View android:layout_width="3dp" android:layout_height="3dp"
                    android:background="@color/border" android:layout_marginHorizontal="@dimen/space_2" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#99F8EFD9" android:textSize="12sp" android:text="Asked 2 min ago" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Tab row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="?android:colorBackground">

        <LinearLayout
            android:id="@+id/tab_row"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_3">

            <TextView android:id="@+id/tab_solution" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:paddingHorizontal="@dimen/space_4"
                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_primary"
                android:text="Solution" />

            <TextView android:id="@+id/tab_concept" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:paddingHorizontal="@dimen/space_4"
                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_tertiary"
                android:text="Concept" />

            <TextView android:id="@+id/tab_practice" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:paddingHorizontal="@dimen/space_4"
                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_tertiary"
                android:text="Practice" />

            <TextView android:id="@+id/tab_pitfalls" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:paddingHorizontal="@dimen/space_4"
                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_tertiary"
                android:text="Pitfalls" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Tab indicator line -->
    <View
        android:id="@+id/tab_indicator"
        android:layout_width="80dp"
        android:layout_height="2dp"
        android:background="@color/brand_primary"
        android:layout_marginStart="@dimen/space_3" />

    <!-- Content pane -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/surface"
        android:scrollbars="none"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_4" />
    </androidx.core.widget.NestedScrollView>

    <!-- Floating follow-up composer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="?android:colorBackground"
        android:elevation="8dp"
        android:padding="@dimen/space_2">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_mascot_milo"
            android:layout_marginStart="@dimen/space_2"
            android:layout_marginEnd="@dimen/space_2"
            android:contentDescription="@string/cd_mascot" />

        <TextView
            android:id="@+id/text_follow_up"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:text="Ask a follow-up..." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            style="@style/Button.Primary"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="@dimen/space_2"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/text_on_primary"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp" />
    </LinearLayout>

</LinearLayout>
