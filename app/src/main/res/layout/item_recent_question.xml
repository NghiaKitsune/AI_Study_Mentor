<?xml version="1.0" encoding="utf-8"?>
<!-- Recent question row for Home screen RecyclerView -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_2"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:orientation="horizontal">

        <!-- Subject color bar — color set programmatically in adapter -->
        <View
            android:id="@+id/view_subject_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/brand_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_3"
            android:paddingVertical="@dimen/space_3">

            <!-- Subject chip + timestamp row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Subject label — background set programmatically -->
                <TextView
                    android:id="@+id/chip_subject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/space_2"
                    android:paddingVertical="2dp"
                    android:textSize="@dimen/text_micro"
                    android:textStyle="bold"
                    tools:text="Math" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/text_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_micro"
                    android:textColor="@color/text_tertiary"
                    tools:text="2h ago" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body_sm"
                android:textStyle="bold"
                tools:text="What is the quadratic formula?" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
