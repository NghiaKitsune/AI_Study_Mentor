<?xml version="1.0" encoding="utf-8"?>
<!-- Quick-start tile used in Home GridLayout -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_columnWeight="1"
    android:layout_gravity="fill_horizontal"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <ImageView
            android:id="@+id/img_tile_icon"
            android:layout_width="@dimen/icon_button_md"
            android:layout_height="@dimen/icon_button_md"
            android:background="@drawable/bg_avatar_circle"
            android:padding="8dp"
            android:src="@drawable/ic_sparkles"
            app:tint="@color/brand_primary_darker"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/text_tile_title"
            style="@style/Text.H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3"
            tools:text="Math" />

        <TextView
            android:id="@+id/text_tile_subtitle"
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1"
            tools:text="Solve a problem" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
