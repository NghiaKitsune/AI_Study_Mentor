<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded amber square — used as background for the app icon on Splash screen -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="21dp"/>
    <gradient
        android:type="linear"
        android:startColor="#FFCF6A"
        android:centerColor="#F5B544"
        android:endColor="#E8960A"
        android:angle="135"/>
</shape>